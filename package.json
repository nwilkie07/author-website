{
		"name": "author-website",
		"private": true,
		"type": "module",
		"scripts": {
				"build": "react-router build",
				"cf-typegen": "wrangler types",
				"deploy": "yarn run build && wrangler deploy",
				"dev": "react-router dev",
				"postinstall": "npm run cf-typegen && node ./postinstall.js",
				"preview": "yarn run build && vite preview",
				"typecheck": "npm run cf-typegen && react-router typegen && tsc -b",
				"db:migrate:add-series-columns": "node scripts/migrate/add-series-columns.ts",
				"db:migrate:add-series-columns:sql": "cat scripts/migrate/add-series-columns.sql"
		},
		"dependencies": {
				"@tinymce/tinymce-react": "^5.3.0",
				"dompurify": "^2.6.0",
