				"isbot": "^5.1.31",
				"lucide-react": "^0.576.0",
				"mailchimp": "^1.2.1",
				"react": "^19.1.1",
				"react-dom": "^19.1.1",
				"react-router": "^7.10.0",
				"tinymce": "^8"
		},
		"devDependencies": {
				"@cloudflare/vite-plugin": "^1.13.5",
				"@react-router/dev": "^7.10.0",
				"@tailwindcss/vite": "^4.1.13",
				"@types/dompurify": "^2.3.1",
